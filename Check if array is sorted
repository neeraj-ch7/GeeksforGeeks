class Solution {
    static boolean fun(int[] arr,int i){
       
           
        if(i==arr.length-1){
            return true;
        }
        if(arr[i]>arr[i+1]){
            return false;
        }
    
        return fun(arr,i+1);
    }
    
    public boolean isSorted(int[] arr) {
        // code here
        int i=0;
        return fun(arr,i);
    }
}
